# Copy to .env.local and fill in your own values. Never commit real credentials.

# --- Database (Azure PostgreSQL Flexible Server, or any compatible Postgres 15+) ---
# Single connection string used by lib/db.ts and most scripts:
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Optional individual vars used by a few standalone scripts (ingest-t3010-history.mjs):
PGHOST=your-server.postgres.database.azure.com
PGPORT=5432
PGDATABASE=opengov
PGUSER=your_admin_user
PGPASSWORD=your_password

# --- Web app access gate ---
# Cookie value clients must present (set via the /?code=... query string on first visit).
ACCESS_CODE=change-me-to-something-secret

# --- Azure OpenAI (used by /api/ask, /api/match, embedding scripts) ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-41
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# Auth: prefer Entra ID managed identity in Azure; for local dev set:
# AZURE_OPENAI_API_KEY=...

# --- Playwright audit tests ---
# Base URL of the deployed (or local) site to audit
BASE_URL=http://localhost:3000
